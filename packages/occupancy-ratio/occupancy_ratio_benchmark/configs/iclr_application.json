{
  "profile": "high_stakes",
  "settings": [
    "rtbgym_discrete",
    "recgym_recommender"
  ],
  "estimators": [
    "neural_fori_default_stable",
    "neural_fori_cv_size",
    "google_dualdice_published_default",
    "dualdice_gmm_tuned",
    "dice_rl_dualdice_recovered",
    "dice_rl_dualdice_gmm_tuned",
    "dice_rl_best_regularized"
  ],
  "seeds": [0, 1, 2, 3, 4],
  "sample_sizes": [1000, 5000],
  "gammas": [0.9, 0.99],
  "include_google_dual_dice": true,
  "include_dice_rl": true,
  "dice_rl_repo_path": "/tmp/dice_rl",
  "google_num_updates": 1000,
  "google_batch_size": 128,
  "google_update_grid": [250, 1000],
  "google_batch_sizes": [128, 256],
  "google_learning_rates": [0.0003, 0.001],
  "google_weight_decays": [0.000001, 0.00001],
  "google_hidden_dims": [128, 256],
  "dice_rl_num_steps": 1000,
  "dice_rl_batch_size": 128,
  "dice_rl_learning_rate": 0.0001,
  "dice_rl_hidden_dims": [64, 64],
  "dice_rl_update_grid": [250, 1000],
  "dice_rl_batch_sizes": [128, 256],
  "dice_rl_learning_rates": [0.0001, 0.0003, 0.001],
  "dice_rl_hidden_dim_grid": [64, 128],
  "neural_num_iterations": 80,
  "neural_gradient_steps_per_iteration": 8,
  "neural_mcmc_samples": 24,
  "neural_batch_size": 512,
  "neural_hidden_dims": [64, 64],
  "neural_action_steps": 1000,
  "neural_transition_steps": 1400,
  "neural_density_ratio_loss": "lsif",
  "neural_fixed_point_damping": 0.5,
  "neural_moment_calibration": "scalar",
  "application_target_value_rollouts": 64,
  "cv_score_method": "bellman_gmm",
  "cv_gmm_objective": "ratio",
  "cv_moment_extra_blocks": ["second_order", "multiscale_rff", "support", "policy_shift"],
  "source_state_correction_mode": "auto",
  "estimator_timeout_sec": 1200,
  "resume": true,
  "write_plots": true
}
