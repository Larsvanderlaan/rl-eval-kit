---
import type { PackageInfo } from '../data/packages';

interface Props {
  pkg: PackageInfo;
}

const { pkg } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const packageHref = `${base}${pkg.href.replace(/^\/+/, '')}`;
---

<article class="rl-card package-card">
  <div class="package-card__topline">
    <span class="eyebrow">{pkg.importName}</span>
    <span class="artifact">{pkg.artifact}</span>
  </div>
  <h3><a href={packageHref}>{pkg.name}</a></h3>
  <p class="tagline">{pkg.tagline}</p>
  <p>{pkg.description}</p>
  <dl class="package-facts">
    <div>
      <dt>For</dt>
      <dd>{pkg.audience}</dd>
    </div>
    <div>
      <dt>Returns</dt>
      <dd>{pkg.artifact}</dd>
    </div>
  </dl>
  <div class="terminal-chip">{pkg.install}</div>
  <a class="text-link" href={packageHref}>Open package guide</a>
</article>
